{
  "name": "carcara-code",
  "version": "0.1.8",
  "description": "IDE minimalista para o Claude Code — cara de Lovable",
  "main": "main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "start": "electron .",
    "test": "vitest run",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky",
    "pack:exe": "vite build && electron-builder --win nsis --publish never",
    "pack:appimage": "vite build && electron-builder --linux AppImage --publish never",
    "pack:dmg": "vite build && electron-builder --mac dmg --universal --publish never",
    "test:i18n": "node scripts/i18n-parity.smoke.cjs",
    "test:csv": "node scripts/csv-smoke.cjs",
    "test:php": "node scripts/php-smoke.cjs",
    "test:rail": "node scripts/rail-smoke.cjs",
    "test:platform": "node scripts/platform-smoke.cjs",
    "test:localpty": "node scripts/localpty-smoke.cjs"
  },
  "lint-staged": {
    "*.{js,jsx,cjs,mjs}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,css,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "build": {
    "appId": "com.carcara.code",
    "productName": "Carcará Code",
    "publish": {
      "provider": "github",
      "owner": "Yg0rAndrade",
      "repo": "carcara-code"
    },
    "directories": {
      "output": "release"
    },
    "files": [
      "**/*",
      "!.claude/**",
      "!.superpowers/**",
      "!docs/**"
    ],
    "npmRebuild": false,
    "asarUnpack": [
      "**/node_modules/node-pty/**"
    ],
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Carcará Code",
      "uninstallDisplayName": "Carcará Code ${version}",
      "artifactName": "CarcaraCode-Setup-${version}.exe"
    },
    "linux": {
      "target": "AppImage",
      "icon": "build/icon.png",
      "category": "Development",
      "artifactName": "CarcaraCode-${version}.AppImage"
    },
    "mac": {
      "target": "dmg",
      "icon": "build/icon.png",
      "category": "public.app-category.developer-tools",
      "hardenedRuntime": false,
      "identity": null,
      "artifactName": "CarcaraCode-${version}-universal.dmg",
      "x64ArchFiles": "**/cpu-features/**"
    },
    "dmg": {
      "title": "Carcará Code ${version}"
    }
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "autoprefixer": "^10.5.0",
    "electron": "^33.2.0",
    "electron-builder": "^26.15.3",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.7.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "postcss": "^8.5.15",
    "prettier": "^3.9.4",
    "tailwindcss": "^3.4.19",
    "vite": "^8.0.16",
    "vitest": "^4.1.9"
  },
  "dependencies": {
    "@assistant-ui/react": "^0.14.26",
    "@assistant-ui/react-markdown": "^0.14.5",
    "@codemirror/lang-cpp": "^6.0.3",
    "@codemirror/lang-css": "^6.3.1",
    "@codemirror/lang-go": "^6.0.1",
    "@codemirror/lang-html": "^6.4.11",
    "@codemirror/lang-java": "^6.0.2",
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/lang-php": "^6.0.2",
    "@codemirror/lang-python": "^6.2.1",
    "@codemirror/lang-rust": "^6.0.2",
    "@codemirror/lang-sql": "^6.10.0",
    "@codemirror/lang-vue": "^0.1.3",
    "@codemirror/lang-xml": "^6.1.0",
    "@codemirror/lang-yaml": "^6.1.3",
    "@codemirror/legacy-modes": "^6.5.3",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.43.1",
    "@fontsource-variable/hanken-grotesk": "^5.2.8",
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "@highlightjs/cdn-assets": "^11.11.1",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@radix-ui/react-select": "^2.3.1",
    "@radix-ui/react-slot": "^1.3.0",
    "@radix-ui/react-switch": "^1.3.1",
    "@radix-ui/react-tabs": "^1.1.15",
    "@radix-ui/react-tooltip": "^1.2.10",
    "@uiw/codemirror-theme-github": "^4.25.10",
    "@uiw/codemirror-theme-vscode": "^4.25.10",
    "@uiw/react-codemirror": "^4.25.10",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/addon-webgl": "^0.19.0",
    "@xterm/xterm": "^6.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "detect-port": "^2.1.0",
    "electron-updater": "^6.8.9",
    "exceljs": "^4.4.0",
    "fabric": "^7.4.0",
    "fix-path": "^5.0.0",
    "highlight.js": "^11.11.1",
    "httpsnippet": "^3.0.10",
    "httpyac": "^6.16.7",
    "lucide": "^1.20.0",
    "lucide-react": "^1.20.0",
    "material-icon-theme": "^5.35.0",
    "motion": "^12.40.0",
    "node-pty": "^1.1.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-markdown": "^10.1.0",
    "react-resizable-panels": "^2.1.9",
    "react-zoom-pan-pinch": "^4.0.3",
    "rehype-highlight": "^7.0.2",
    "remark-gfm": "^4.0.1",
    "simple-git": "^3.36.0",
    "ssh2": "^1.17.0",
    "tailwind-merge": "^3.6.0",
    "tailwindcss-animate": "^1.0.7",
    "tldraw": "^5.1.1",
    "xlsx": "^0.18.5"
  }
}
