# EditorConfig — regras básicas pro editor, alinhadas ao Prettier e ao .gitattributes (LF).
# Editores que não rodam o Prettier ainda produzem indentação, charset e fim de linha
# consistentes, evitando diffs de ruído. https://editorconfig.org
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

# Markdown: espaços à direita podem ser quebra de linha intencional.
[*.md]
trim_trailing_whitespace = false
